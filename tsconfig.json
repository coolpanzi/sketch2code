{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/code-gen.ts",
    "src/component-analyzer.ts",
    "src/layout-engine.ts",
    "src/region-detector.ts",
    "src/token-extractor.ts",
    "src/output-generator.ts",
    "src/png-renderer.ts",
    "src/verification.ts",
    "src/core/codegen/CodeGenerator.ts",
    "src/core/codegen/CodeGeneratorEnhanced.ts",
    "src/core/codegen/HighFidelityGenerator.ts"
  ]
}
